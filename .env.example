# Environment Contract (do not store real secrets here)
#
# Legend:
# [L] required local dev
# [V] required preview
# [P] required production
# [O] optional

# -----------------------------------------------------------------------------
# Auth + App URLs
# -----------------------------------------------------------------------------
# [L,V,P] Must be present and MUST match each other.
JWT_SECRET=
NEXTAUTH_SECRET=

# [L,V,P] Canonical auth callback URL.
# local example: http://localhost:3000
# preview example: https://<preview-domain>
# prod example: https://www.blackwealthexchange.com
NEXTAUTH_URL=

# [V,P] [O in local] Absolute app URL used by server-side links.
APP_URL=

# [V,P] [O in local] Public app URL fallback.
NEXT_PUBLIC_APP_URL=

# [O] Public metadata/base URL used by runtime config and client links.
NEXT_PUBLIC_BASE_URL=

# [O] Optional dedicated reset-token secret (falls back to JWT_SECRET).
RESET_TOKEN_SECRET=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# [L,V,P] Mongo connection string.
# local example: mongodb://127.0.0.1:27017
# preview/prod: managed Mongo endpoint (never localhost)
MONGODB_URI=

# [L,V,P] Mongo DB name.
MONGODB_DB=bwes-cluster

# -----------------------------------------------------------------------------
# Stripe (required if checkout/payment flows are exercised)
# -----------------------------------------------------------------------------
# [V,P] [O in local] Server-side Stripe secret key
STRIPE_SECRET_KEY=

# [V,P] [O in local] Client-side publishable key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# [V,P] [O in local] Stripe webhook signature secret
STRIPE_WEBHOOK_SECRET=

# [O] Platform connect account id (acct_...)
PLATFORM_STRIPE_ACCOUNT_ID=

# -----------------------------------------------------------------------------
# Optional Email/SMTP (when email workflows are enabled)
# -----------------------------------------------------------------------------
# [O]
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
